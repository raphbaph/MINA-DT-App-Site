---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import UpdateCard from "../../components/UpdateCard.astro";

const updates = (await getCollection("updates", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
---

<BaseLayout title="Updates · MINA DT App">
  <section class="mx-auto max-w-[820px] px-5 py-12 md:py-16">
    <span class="chip">Updates</span>
    <h1 class="mt-3 font-display text-4xl md:text-5xl">Community updates</h1>
    <p class="mt-3 max-w-[60ch] text-lg text-ink-soft">
      Proposals and community updates for the MINA Decentralized Treasury App. More are
      forthcoming — start with the <a href="/" class="font-medium">primer</a>.
    </p>

    {updates.length > 0 ? (
      <ul class="mt-10 space-y-4">
        {updates.map((entry) => (
          <li><UpdateCard entry={entry} heading="h2" /></li>
        ))}
      </ul>
    ) : (
      <div class="mt-10 rounded-2xl border border-line bg-paper/55 p-8 text-center backdrop-blur-sm">
        <p class="text-ink-soft">Community updates are forthcoming. Check back soon.</p>
      </div>
    )}
  </section>
</BaseLayout>
