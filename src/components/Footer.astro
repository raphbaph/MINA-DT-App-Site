---
import { Image } from "astro:assets";
import logo from "../assets/mina-logo.png";
const year = new Date().getFullYear();
const twitterUrl = "https://x.com/MinaFoundation";
const linkedinUrl = "https://www.linkedin.com/company/mina-foundation/";
const websiteUrl = "https://www.minafoundation.com/";
---

<footer class="mt-24 bg-ink text-[rgb(205_217_225_/_0.85)]">
  <div class="mx-auto max-w-[1180px] px-5 py-12">
    <div class="flex flex-wrap items-start justify-between gap-8">
      <div>
        <Image
          src={logo}
          alt="MINA Decentralized Treasury"
          width={104}
          height={104}
          class="mb-4 h-14 w-14 rounded-md"
        />
        <p class="eyebrow !text-[rgb(183_205_216_/_0.7)]">MINA Foundation</p>
        <p class="mt-1 font-display text-xl text-white">
          Decentralized Treasury
        </p>
        <p class="mt-3 max-w-[58ch] text-sm">
          A community primer on the MINA Decentralized Treasury App. Data points reflect
          the source reports and should be confirmed before acting on them.
        </p>
      </div>
      <nav class="flex items-center gap-3" aria-label="Footer">
        <a
          href={websiteUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="MINA Foundation website"
          class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/15 text-[rgb(205_217_225_/_0.85)] no-underline transition hover:border-white/40 hover:text-white"
        >
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="9"></circle>
            <ellipse cx="12" cy="12" rx="4" ry="9"></ellipse>
            <line x1="3" y1="12" x2="21" y2="12"></line>
          </svg>
        </a>
        <a
          href={linkedinUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="MINA Foundation on LinkedIn"
          class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/15 text-[rgb(205_217_225_/_0.85)] no-underline transition hover:border-white/40 hover:text-white"
        >
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"></path>
          </svg>
        </a>
        <a
          href={twitterUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="MINA Foundation on X (Twitter)"
          class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/15 text-[rgb(205_217_225_/_0.85)] no-underline transition hover:border-white/40 hover:text-white"
        >
          <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path>
          </svg>
        </a>
      </nav>
    </div>
    <p class="mt-10 text-xs text-[rgb(183_205_216_/_0.55)]">
      &copy; {year} · Published for the MINA community.
    </p>
  </div>
</footer>
