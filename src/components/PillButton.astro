---
// Pill-style link button. variant: "primary" (periwinkle) | "secondary" (outline).
interface Props {
  href: string;
  variant?: "primary" | "secondary";
  external?: boolean;
  class?: string;
}
const { href, variant = "primary", external = false, class: cls = "" } = Astro.props;
const ext = external ? { target: "_blank", rel: "noopener noreferrer" } : {};
---

<a href={href} class={`pill pill-${variant} ${cls}`} {...ext}>
  <slot />
</a>
