---
// Pill-style link button. variant: "primary" (full amber) | "secondary" (white outline)
// | "soft" (washed amber + amber border).
interface Props {
  href: string;
  variant?: "primary" | "secondary" | "soft";
  external?: boolean;
  class?: string;
}
const { href, variant = "primary", external = false, class: cls = "" } = Astro.props;
const ext = external ? { target: "_blank", rel: "noopener noreferrer" } : {};
---

<a href={href} class={`pill pill-${variant} ${cls}`} {...ext}>
  <slot />
</a>
