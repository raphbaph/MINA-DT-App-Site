---
// Native SVG recreation of the deployment-cadence flow (replaces a raster export).
// Phases as rounded boxes, transition criteria as diamonds, on-brand cool palette.
interface Props {
  caption?: string;
  class?: string;
}
const { caption, class: cls = "my-7" } = Astro.props;
const ink = "#2d2d2d";
const fill = "#e3e6f6"; // lavender secondary
const stroke = "#b7c0ee";
---

<figure class={cls}>
  <div class="glass p-5 md:p-8">
    <svg
      viewBox="0 0 800 500"
      role="img"
      aria-label="Deployment flow: Test Phase advances (2 proposals, 2 months, or treasury spent) to Scale Up Phase, then (4 proposals, 3 months, or treasury spent) to Final Deployment where signer authority is dropped and break-glass signers are sent to burn."
      class="h-auto w-full"
      font-family="IBM Plex Sans, system-ui, sans-serif"
    >
      <defs>
        <marker id="fa" markerWidth="9" markerHeight="9" refX="7" refY="4" orient="auto">
          <path d="M0,0 L8,4 L0,8 z" fill={ink}></path>
        </marker>
      </defs>

      <!-- Boxes & diamonds -->
      <rect x="24" y="24" width="150" height="160" rx="14" fill={fill} stroke={stroke}></rect>
      <polygon points="380,24 480,104 380,184 280,104" fill={fill} stroke={stroke}></polygon>
      <rect x="575" y="14" width="170" height="180" rx="14" fill={fill} stroke={stroke}></rect>
      <polygon points="660,300 760,380 660,460 560,380" fill={fill} stroke={stroke}></polygon>
      <rect x="310" y="305" width="150" height="150" rx="14" fill={fill} stroke={stroke}></rect>
      <circle cx="92" cy="380" r="74" fill={fill} stroke={stroke}></circle>

      <!-- Arrows (lengthened for breathing room) -->
      <line x1="178" y1="104" x2="276" y2="104" stroke={ink} stroke-width="2" marker-end="url(#fa)"></line>
      <line x1="482" y1="104" x2="573" y2="104" stroke={ink} stroke-width="2" marker-end="url(#fa)"></line>
      <line x1="660" y1="196" x2="660" y2="296" stroke={ink} stroke-width="2" marker-end="url(#fa)"></line>
      <line x1="558" y1="380" x2="464" y2="380" stroke={ink} stroke-width="2" marker-end="url(#fa)"></line>
      <line x1="308" y1="380" x2="172" y2="380" stroke={ink} stroke-width="2" marker-end="url(#fa)"></line>

      <!-- Box / diamond text -->
      <text text-anchor="middle" font-size="14" fill={ink}>
        <tspan x="99" y="99">Test Phase</tspan><tspan x="99" y="118">Deployment</tspan>
      </text>
      <text text-anchor="middle" font-size="14" fill={ink}>
        <tspan x="660" y="95">Scale Up Phase</tspan><tspan x="660" y="114">Deployment</tspan>
      </text>
      <text text-anchor="middle" font-size="14" fill={ink}>
        <tspan x="385" y="375">Final</tspan><tspan x="385" y="394">Deployment</tspan>
      </text>
      <text text-anchor="middle" font-size="13" fill={ink}>
        <tspan x="380" y="80">2 proposals</tspan><tspan x="380" y="98">OR 2 months</tspan><tspan x="380" y="116">pass OR</tspan><tspan x="380" y="134">Treasury spent</tspan>
      </text>
      <text text-anchor="middle" font-size="13" fill={ink}>
        <tspan x="660" y="356">4 proposals</tspan><tspan x="660" y="374">OR 3 months</tspan><tspan x="660" y="392">pass OR</tspan><tspan x="660" y="410">Treasury spent</tspan>
      </text>

      <!-- Edge labels -->
      <text text-anchor="middle" font-size="12" fill={ink}>
        <tspan x="511" y="350">Signer Authority</tspan><tspan x="511" y="366">dropped</tspan>
      </text>
      <text text-anchor="middle" font-size="12" fill={ink}>
        <tspan x="92" y="366">Break Glass</tspan><tspan x="92" y="382">signers sent</tspan><tspan x="92" y="398">to burn</tspan>
      </text>
    </svg>
  </div>
  {caption && <figcaption class="mt-2 text-sm text-ink-soft">{caption}</figcaption>}
</figure>
