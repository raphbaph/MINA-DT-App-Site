---
import { Image } from "astro:assets";
import PillButton from "./PillButton.astro";
import logo from "../assets/mina-logo.png";
const sections = [
  { href: "/#concept", label: "Concept" },
  { href: "/#lifecycle", label: "Lifecycle" },
  { href: "/#thresholds", label: "Thresholds" },
  { href: "/#deployment", label: "Deployment" },
  { href: "/#safeguards", label: "Safeguards" },
];
---

<div class="sticky top-3 z-40 mt-8 px-3 md:top-4 md:mt-10 md:px-5">
  <header class="glass-header mx-auto flex max-w-[1180px] items-center justify-between gap-3 px-4 py-3 backdrop-blur-[40px] backdrop-saturate-150 md:gap-4 md:px-7 md:py-4">
    <a href="/" class="flex min-w-0 items-center gap-2.5 no-underline md:gap-3">
      <Image
        src={logo}
        alt="MINA Decentralized Treasury"
        width={96}
        height={96}
        class="h-9 w-9 shrink-0 rounded-md md:h-11 md:w-11"
      />
      <span class="min-w-0 leading-tight">
        <span class="eyebrow block">MINA Foundation</span>
        <span class="block truncate font-display text-base text-ink md:text-xl">
          Decentralized&nbsp;Treasury
        </span>
      </span>
    </a>

    <nav aria-label="Primary" class="flex shrink-0 items-center gap-5">
      <ul class="hidden items-center gap-6 text-sm font-medium lg:flex">
        {
          sections.map((s) => (
            <li>
              <a href={s.href} class="text-ink-soft no-underline hover:text-accent">
                {s.label}
              </a>
            </li>
          ))
        }
      </ul>
      <PillButton href="/updates" class="!px-5 !py-2.5 text-sm">Updates</PillButton>
    </nav>
  </header>
</div>
