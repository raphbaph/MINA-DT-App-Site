---
interface Props {
  proposalHref?: string;
}
const { proposalHref = "/updates/proposal-v1" } = Astro.props;
---

<section class="mx-auto max-w-[1100px] px-5 pt-14 pb-8 md:pt-20">
  <p class="mb-3 font-mono text-sm tracking-wide text-accent">
    MINA Decentralized Treasury
  </p>
  <h1 class="max-w-[18ch] font-display text-4xl md:text-6xl">
    A community-run treasury, deployed in deliberate steps.
  </h1>
  <p class="mt-5 max-w-[62ch] text-lg text-ink-soft">
    A guide to the DT App: a MINA-native ZK app that lets the community gradually
    take control of the decentralized treasury through an adaptive proposal
    lifecycle, S-curve quorum thresholds, a phased deployment cadence, and a
    break-glass safeguard that is removed once the community can stand on its own.
  </p>
  <div class="mt-8 flex flex-wrap gap-3">
    <a
      href="#calculator"
      class="inline-flex items-center rounded-full bg-accent px-6 py-3 font-medium text-accent-ink no-underline transition hover:opacity-90"
    >
      Try the threshold calculator
    </a>
    <a
      href={proposalHref}
      class="inline-flex items-center rounded-full border border-line bg-paper px-6 py-3 font-medium text-ink no-underline transition hover:border-accent"
    >
      Read the full proposal
    </a>
  </div>
</section>
