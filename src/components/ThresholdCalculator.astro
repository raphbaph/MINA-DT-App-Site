---
// Interactive island. The calculation logic is ported verbatim from the original
// js/calculator.js — constants and formulas unchanged.
---

<section id="calculator" class="mx-auto max-w-[1100px] px-5 py-10">
  <div class="glass p-6 md:p-9">
    <h2 class="font-display text-2xl md:text-3xl">Adaptive threshold calculator</h2>
    <p class="mt-2 max-w-[60ch] text-ink-soft">
      Pick a deployment phase and a proposal ask (as a share of that phase's
      treasury) to see the required participation and approval, and the MINA
      figures behind them.
    </p>

    <div class="mt-6 grid gap-6 md:grid-cols-2">
      <div>
        <label for="phase" class="mb-1 block font-medium">Deployment phase</label>
        <select
          id="phase"
          class="select w-full rounded-lg border border-line bg-paper py-2.5 pl-3 pr-10 font-medium"
        >
          <option value="test">Test Phase — 1,000k MINA</option>
          <option value="scale">Scale Up Phase — 20,000k MINA</option>
          <option value="final">Final Deployment — 34,000k MINA</option>
        </select>
      </div>
      <div>
        <label for="ask" class="mb-1 block font-medium">
          Proposal ask: <span id="askLabel" class="font-mono text-accent">10%</span>
        </label>
        <input
          id="ask"
          type="range"
          min="1"
          max="100"
          value="10"
          class="mt-3 w-full accent-[var(--color-accent)]"
        />
      </div>
    </div>

    <div class="mt-7 grid gap-6 sm:grid-cols-2" aria-live="polite">
      <div class="border-l-2 border-accent pl-4">
        <p class="text-sm text-ink-soft">Participation required</p>
        <p id="participationOut" class="font-display text-3xl text-ink">—</p>
        <p id="participationMina" class="mt-1 font-mono text-sm text-ink-soft"></p>
      </div>
      <div class="border-l-2 border-accent pl-4">
        <p class="text-sm text-ink-soft">Approval required</p>
        <p id="approvalOut" class="font-display text-3xl text-ink">—</p>
        <p id="approvalMina" class="mt-1 font-mono text-sm text-ink-soft"></p>
      </div>
    </div>

    <p id="askOut" class="mt-5 font-mono text-sm text-ink" aria-live="polite"></p>
  </div>
</section>

<script>
  const phases = {
    test: { treasuryK: 1000, modifier: 0.05 },
    scale: { treasuryK: 20000, modifier: 0.28 },
    final: { treasuryK: 34000, modifier: 0.45 },
  };

  const circulatingK = 1288500;
  const ask = document.querySelector("#ask") as HTMLInputElement;
  const phase = document.querySelector("#phase") as HTMLSelectElement;
  const askLabel = document.querySelector("#askLabel") as HTMLElement;
  const participationOut = document.querySelector("#participationOut") as HTMLElement;
  const approvalOut = document.querySelector("#approvalOut") as HTMLElement;
  const participationMina = document.querySelector("#participationMina") as HTMLElement;
  const approvalMina = document.querySelector("#approvalMina") as HTMLElement;
  const askOut = document.querySelector("#askOut") as HTMLElement;

  function curve(x: number, c: number) {
    return x / (x + c * (1 - x));
  }

  function formatK(value: number) {
    return Math.round(value).toLocaleString("en-US") + "k MINA";
  }

  function updateCalculator() {
    const selected = phases[phase.value as keyof typeof phases];
    const askPercent = Number(ask.value);
    const x = Math.min(askPercent / 100, 1);
    const participationBp = 2000 + (5000 - 2000) * curve(x, 0.05);
    const approvalBp = 5100 + (7000 - 5100) * curve(x, 0.1);
    const participationSupplyPct = (selected.modifier * participationBp) / 100;
    const approvalRatioPct = approvalBp / 100;
    const participationK = (circulatingK * participationSupplyPct) / 100;
    const approvalK = (participationK * approvalRatioPct) / 100;
    const askK = (selected.treasuryK * askPercent) / 100;

    askLabel.textContent = askPercent + "%";
    participationOut.textContent = participationSupplyPct.toFixed(2) + "%";
    approvalOut.textContent = approvalRatioPct.toFixed(2) + "%";
    participationMina.textContent = formatK(participationK) + " voting weight";
    approvalMina.textContent = formatK(approvalK) + " minimum yay at participation floor";
    askOut.textContent =
      "Estimated ask: " + formatK(askK) + " from the selected treasury.";
  }

  ask.addEventListener("input", updateCalculator);
  phase.addEventListener("change", updateCalculator);
  updateCalculator();
</script>
