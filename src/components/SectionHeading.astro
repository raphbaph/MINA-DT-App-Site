---
// Section kicker (amber chip) + serif headline, with an optional intro via the slot.
interface Props {
  eyebrow: string;
  title: string;
  headingClass?: string;
}
const { eyebrow, title, headingClass = "max-w-[20ch] text-3xl md:text-5xl" } = Astro.props;
---

<span class="chip">{eyebrow}</span>
<h2 class={`mt-4 font-display ${headingClass}`}>{title}</h2>
<slot />
